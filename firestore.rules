rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each signed-in user can only read/write documents anywhere under their own
    // users/{uid} space — this covers the Ballpark Tracker's "visits" collection
    // AND this app's "theatreVisits" collection (and any future tracker you add
    // to this same Firebase project), all in one rule.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
